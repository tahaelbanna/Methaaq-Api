				{
					"name": "Create Project",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Build an E-commerce App\",\n    \"description\": \"I need a full stack developer to build a MERN stack app...\",\n    \"budget\": 5000,\n    \"deadline\": \"2026-12-01\"\n}",
							"options": { "raw": { "language": "json" } }
