				{
					"name": "Get All Projects",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/projects?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["projects"], "query": [ { "key": "page", "value": "1" }, { "key": "limit", "value": "10" } ] }
					}
				},
				{
					"name": "Get One Project",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/projects/1", "host": ["{{baseUrl}}"], "path": ["projects", "1"] }
					}
				},
				{
					"name": "Update Project",
					"request": {
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"budget\": 6000\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/projects/1", "host": ["{{baseUrl}}"], "path": ["projects", "1"] }
					}
				},
				{
					"name": "Delete Project",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": { "raw": "{{baseUrl}}/projects/1", "host": ["{{baseUrl}}"], "path": ["projects", "1"] }
					}
				}
			]
		},
