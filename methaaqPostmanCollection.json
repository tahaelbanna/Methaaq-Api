		{
			"name": "10. Socket.io (Info)",
			"item": [
				{
					"name": "How to test Socket.io in Postman",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "ws://localhost:8000", "host": ["ws", "", "localhost"], "port": "8000" },
						"description": "1. In Postman, click 'New' -> 'WebSocket Request' or 'Socket.io'.\n2. Set URL to `ws://localhost:8000` (or your port).\n3. In 'Headers' tab, add Key: `token` and Value: `{{accessToken}}`.\n4. Click Connect.\n5. To test joining a room, emit event `join_contract` with message `1` (contract ID).\n6. To mark read, emit event `mark_messages_read` with message `1`."
					}
				}
			]
		}
